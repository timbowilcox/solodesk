# SoloDesk — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must never be committed.
# Repo is public on GitHub — treat all real secrets as if a leak is permanent.

# --- Supabase (Sydney project: ap-southeast-2) ---
NEXT_PUBLIC_SUPABASE_URL=REPLACE_ME
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# --- Resend (solodesk.ai domain verified) ---
RESEND_API_KEY=REPLACE_ME

# --- Shared secrets (generate 64-char hex, e.g. `openssl rand -hex 32`) ---
WEBHOOK_SECRET=REPLACE_ME
CRON_SECRET=REPLACE_ME

# --- Inference (not used in Sprint 0; seed for later sprints) ---
ANTHROPIC_API_KEY=REPLACE_ME

# --- Embeddings (Sprint 0.5+) ---
VOYAGE_API_KEY=REPLACE_ME

# --- Seed admin email (used by the SQL seed, not the running app) ---
ALLOWED_EMAIL=tim@solodesk.ai
